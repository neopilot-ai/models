{
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "typescript": "5.8.2",
      "@types/node": "22.13.9",
      "@types/bun": "1.3.0",
      "zod": "3.24.2",
      "ai": "4.3.16",
      "@tsconfig/bun": "^1.0.8"
    }
  },
  "scripts": {
    "validate": "bun ./packages/core/script/validate.ts",
    "helicone:generate": "bun ./packages/core/script/generate-helicone.ts",
    "venice:generate": "bun ./packages/core/script/generate-venice.ts",
    "vercel:generate": "bun ./packages/core/script/generate-vercel.ts",
    "build": "cd packages/web && bun run build",
    "deploy": "echo 'Deploy to GitHub Pages via GitHub Actions'",
    "rust:build": "cargo build --release",
    "rust:run": "cargo run --bin neopilot-models",
    "rust:serve": "cargo run --bin neopilot-models -- serve",
    "rust:validate": "cargo run --bin neopilot-models -- validate",
    "rust:stats": "cargo run --bin neopilot-models -- stats",
    "rust:test": "cargo test",
    "rust:bench": "cargo bench"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250801.0"
  }
}